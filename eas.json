{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "envSecretFiles": {
        "GOOGLE_SERVICES_JSON": "./google-services.json"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "envSecretFiles": {
        "GOOGLE_SERVICES_JSON": "./google-services.json"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
